//@version=6
strategy(
     "UT Alternative Indicators Championship v5.0",
     overlay = true,
     initial_capital = 100000,
     pyramiding = 0,
     commission_type = strategy.commission.percent,
     commission_value = 0.01,
     slippage = 1,
     process_orders_on_close = true
)

// Open, inspectable research implementations.
// The B-Xtrender-style filters below are original approximations built from
// common RSI, EMA, and momentum concepts. They do not copy or republish
// another author's Pine source code.

competitor = input.string(
     "UT Original",
     "Competitor",
     options = [
         "UT Original",
         "UT + B-Xtrender Style",
         "UT + EMA200 + B-Xtrender Style",
         "UT + RSI + B-Xtrender Style",
         "UT + MACD + B-Xtrender Style",
         "UT + Linear Regression Trend",
         "UT + EMA200 + Linear Regression",
         "UT + Smoothed Heiken Ashi",
         "UT + EMA200 + Smoothed Heiken Ashi",
         "UT + ADR Volatility",
         "UT + ADR Dynamic Target",
         "UT + B-Xtrender Style + Linear Regression",
         "UT + B-Xtrender Style + Smoothed Heiken Ashi",
         "UT + Linear Regression + Smoothed Heiken Ashi",
         "UT + B-Xtrender Style + ADR",
         "UT + EMA200 + B-Xtrender Style + ADR",
         "UT + EMA200 + Linear Regression + ADR",
         "UT + EMA200 + Smoothed Heiken Ashi + ADR",
         "UT + B-Xtrender Style + Linear Regression + SHA",
         "UT + All Alternative Filters"
     ]
)

sensitivity = input.float(1.0, "UT Sensitivity", minval = 0.1, step = 0.1)
atrPeriod = input.int(10, "UT ATR Period", minval = 1)
positionPercent = input.float(15.0, "Position Size %", minval = 1, maxval = 100)
maximumBarsHeld = input.int(20, "Maximum Bars Held", minval = 1)
hardStopPercent = input.float(3.0, "Hard Stop %", minval = 0.1, step = 0.1)
takeProfitPercent = input.float(8.0, "Base Take Profit %", minval = 0.1, step = 0.1)

emaLength = input.int(200, "EMA Length", minval = 20)
regressionLength = input.int(50, "Linear Regression Length", minval = 5)
shaSmoothLength = input.int(10, "Smoothed Heiken Ashi Length", minval = 2)
adrLength = input.int(20, "ADR Length", minval = 2)
adrMinimumPercent = input.float(0.8, "Minimum ADR %", minval = 0.0, step = 0.1)
adrTargetMultiplier = input.float(1.0, "ADR Target Multiplier", minval = 0.1, step = 0.1)

src = close
atrValue = ta.atr(atrPeriod)
lossDistance = sensitivity * atrValue

var float utStop = na
previousStop = nz(utStop[1], src)
previousSource = nz(src[1], src)

utStop :=
     src > previousStop and previousSource > previousStop
         ? math.max(previousStop, src - lossDistance)
     : src < previousStop and previousSource < previousStop
         ? math.min(previousStop, src + lossDistance)
     : src > previousStop
         ? src - lossDistance
     : src + lossDistance

utBuy = ta.crossover(src, utStop)
utSell = ta.crossunder(src, utStop)

ema200 = ta.ema(close, emaLength)
rsi14 = ta.rsi(close, 14)
[macdLine, macdSignal, _] = ta.macd(close, 12, 26, 9)

// Original B-Xtrender-style approximation:
// short component combines fast RSI and EMA momentum;
// long component combines slower RSI and EMA momentum.
fastMomentum = ta.ema(ta.rsi(close, 5) - 50.0, 5)
slowMomentum = ta.ema(ta.rsi(close, 14) - 50.0, 8)
emaMomentum = 100.0 * (ta.ema(close, 5) - ta.ema(close, 20)) / math.max(close, 0.0001)
bXShort = fastMomentum + emaMomentum
bXLong = slowMomentum + ta.ema(emaMomentum, 5)
bXPass = bXShort > 0 and bXLong > 0 and bXShort > bXShort[1]

regressionValue = ta.linreg(close, regressionLength, 0)
regressionPrevious = ta.linreg(close, regressionLength, 1)
regressionPass = close > regressionValue and regressionValue > regressionPrevious

smoothOpen = ta.ema(open, shaSmoothLength)
smoothHigh = ta.ema(high, shaSmoothLength)
smoothLow = ta.ema(low, shaSmoothLength)
smoothClose = ta.ema(close, shaSmoothLength)

var float shaOpen = na
shaClose = (smoothOpen + smoothHigh + smoothLow + smoothClose) / 4.0
shaOpen := na(shaOpen[1]) ? (smoothOpen + smoothClose) / 2.0 : (shaOpen[1] + shaClose[1]) / 2.0
shaHigh = math.max(smoothHigh, math.max(shaOpen, shaClose))
shaLow = math.min(smoothLow, math.min(shaOpen, shaClose))
shaPass = shaClose > shaOpen and shaClose > shaClose[1]

dailyRange = request.security(
     syminfo.tickerid,
     "D",
     high - low,
     lookahead = barmerge.lookahead_off
)
dailyClose = request.security(
     syminfo.tickerid,
     "D",
     close,
     lookahead = barmerge.lookahead_off
)
adr = ta.sma(dailyRange, adrLength)
adrPercent = 100.0 * adr / math.max(dailyClose, 0.0001)
adrPass = adrPercent >= adrMinimumPercent

emaPass = close > ema200
rsiPass = rsi14 > 50 and rsi14 < 75
macdPass = macdLine > macdSignal

filterPass =
     competitor == "UT Original" ? true :
     competitor == "UT + B-Xtrender Style" ? bXPass :
     competitor == "UT + EMA200 + B-Xtrender Style" ? emaPass and bXPass :
     competitor == "UT + RSI + B-Xtrender Style" ? rsiPass and bXPass :
     competitor == "UT + MACD + B-Xtrender Style" ? macdPass and bXPass :
     competitor == "UT + Linear Regression Trend" ? regressionPass :
     competitor == "UT + EMA200 + Linear Regression" ? emaPass and regressionPass :
     competitor == "UT + Smoothed Heiken Ashi" ? shaPass :
     competitor == "UT + EMA200 + Smoothed Heiken Ashi" ? emaPass and shaPass :
     competitor == "UT + ADR Volatility" ? adrPass :
     competitor == "UT + ADR Dynamic Target" ? adrPass :
     competitor == "UT + B-Xtrender Style + Linear Regression" ? bXPass and regressionPass :
     competitor == "UT + B-Xtrender Style + Smoothed Heiken Ashi" ? bXPass and shaPass :
     competitor == "UT + Linear Regression + Smoothed Heiken Ashi" ? regressionPass and shaPass :
     competitor == "UT + B-Xtrender Style + ADR" ? bXPass and adrPass :
     competitor == "UT + EMA200 + B-Xtrender Style + ADR" ? emaPass and bXPass and adrPass :
     competitor == "UT + EMA200 + Linear Regression + ADR" ? emaPass and regressionPass and adrPass :
     competitor == "UT + EMA200 + Smoothed Heiken Ashi + ADR" ? emaPass and shaPass and adrPass :
     competitor == "UT + B-Xtrender Style + Linear Regression + SHA" ? bXPass and regressionPass and shaPass :
     emaPass and bXPass and regressionPass and shaPass and adrPass

entrySignal = barstate.isconfirmed and utBuy and filterPass
exitSignal = barstate.isconfirmed and utSell

var int entryBar = na

if strategy.position_size == 0
    entryBar := na

if entrySignal and strategy.position_size == 0
    strategy.entry(
         "UT-LONG",
         strategy.long,
         qty = (strategy.equity * positionPercent / 100.0) / close
    )
    entryBar := bar_index

if strategy.position_size > 0
    stopPrice = strategy.position_avg_price * (1.0 - hardStopPercent / 100.0)
    fixedTarget = strategy.position_avg_price * (1.0 + takeProfitPercent / 100.0)
    adrTarget = strategy.position_avg_price + adr * adrTargetMultiplier
    targetPrice = competitor == "UT + ADR Dynamic Target" ? adrTarget : fixedTarget
    barsHeld = na(entryBar) ? 0 : bar_index - entryBar

    strategy.exit(
         "UT-RISK-EXIT",
         from_entry = "UT-LONG",
         stop = stopPrice,
         limit = targetPrice
    )

    if exitSignal or barsHeld >= maximumBarsHeld
        strategy.close(
             "UT-LONG",
             comment = exitSignal ? "UT_SELL" : "TIME_EXIT"
        )

plot(utStop, "UT ATR Stop")
plot(ema200, "EMA 200")
plot(regressionValue, "Linear Regression")
plot(shaClose, "Smoothed HA Close")

plotshape(
     entrySignal and strategy.position_size == 0,
     title = "UT Buy",
     text = "UT BUY",
     style = shape.labelup,
     location = location.belowbar,
     size = size.tiny
)

plotshape(
     exitSignal and strategy.position_size > 0,
     title = "UT Sell",
     text = "UT SELL",
     style = shape.labeldown,
     location = location.abovebar,
     size = size.tiny
)
