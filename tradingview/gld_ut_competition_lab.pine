//@version=6
strategy("GLD UT Competition Lab v2.1", overlay=true, initial_capital=100000, pyramiding=0, commission_type=strategy.commission.percent, commission_value=0.01, slippage=1, process_orders_on_close=true)

// Open, inspectable UT-style ATR trailing-stop research implementation.

variant = input.string("UT + EMA200", "Strategy Variant", options=["UT Original","UT + EMA200","UT + Volume","UT + Session","UT + EMA200 + Volume","UT + Higher Timeframe"])
keyValue = input.float(1.0, "Sensitivity", minval=0.1, step=0.1)
atrPeriod = input.int(10, "ATR Period", minval=1)
emaLength = input.int(200, "EMA Trend Length", minval=20)
volumeLength = input.int(20, "Volume Average Length", minval=2)
sessionInput = input.session("0930-1130", "Opening Session")
higherTimeframe = input.timeframe("240", "Higher Timeframe")
positionPercent = input.float(15.0, "Position Size %", minval=1, maxval=100)
stopLossPercent = input.float(3.0, "Hard Stop %", minval=0.1)
takeProfitPercent = input.float(8.0, "Take Profit %", minval=0.1)
maximumBarsHeld = input.int(20, "Maximum Bars Held", minval=1)

src = close
atrValue = ta.atr(atrPeriod)
lossDistance = keyValue * atrValue

var float atrTrailingStop = na
previousStop = nz(atrTrailingStop[1], src)
previousSource = nz(src[1], src)

atrTrailingStop :=
     src > previousStop and previousSource > previousStop ? math.max(previousStop, src - lossDistance) :
     src < previousStop and previousSource < previousStop ? math.min(previousStop, src + lossDistance) :
     src > previousStop ? src - lossDistance : src + lossDistance

utBuy = ta.crossover(src, atrTrailingStop)
utSell = ta.crossunder(src, atrTrailingStop)

emaTrend = ta.ema(close, emaLength)
volumeAverage = ta.sma(volume, volumeLength)
inOpeningSession = not na(time(timeframe.period, sessionInput))
higherClose = request.security(syminfo.tickerid, higherTimeframe, close, lookahead=barmerge.lookahead_off)
higherEma = request.security(syminfo.tickerid, higherTimeframe, ta.ema(close, emaLength), lookahead=barmerge.lookahead_off)

variantFilter =
     variant == "UT Original" ? true :
     variant == "UT + EMA200" ? close > emaTrend :
     variant == "UT + Volume" ? volume > volumeAverage :
     variant == "UT + Session" ? inOpeningSession :
     variant == "UT + EMA200 + Volume" ? close > emaTrend and volume > volumeAverage :
     higherClose > higherEma

entrySignal = barstate.isconfirmed and utBuy and variantFilter
exitSignal = barstate.isconfirmed and utSell

var int entryBar = na
if strategy.position_size == 0
    entryBar := na

if entrySignal and strategy.position_size == 0
    strategy.entry("UT-LONG", strategy.long, qty=(strategy.equity * positionPercent / 100.0) / close, alert_message='{"source":"tradingview","strategy":"gld_ut_competition","variant":"' + variant + '","event":"BUY","ticker":"{{ticker}}","timeframe":"{{interval}}","price":{{close}}}')
    entryBar := bar_index

if strategy.position_size > 0
    stopPrice = strategy.position_avg_price * (1.0 - stopLossPercent / 100.0)
    targetPrice = strategy.position_avg_price * (1.0 + takeProfitPercent / 100.0)
    barsHeld = na(entryBar) ? 0 : bar_index - entryBar
    strategy.exit("UT-RISK-EXIT", from_entry="UT-LONG", stop=stopPrice, limit=targetPrice)
    if exitSignal or barsHeld >= maximumBarsHeld
        strategy.close("UT-LONG", comment=exitSignal ? "UT_SELL" : "TIME_EXIT")

plot(atrTrailingStop, "UT ATR Stop")
plot(emaTrend, "EMA 200")
plotshape(entrySignal and strategy.position_size == 0, title="UT Buy", text="UT BUY", style=shape.labelup, location=location.belowbar, size=size.tiny)
plotshape(exitSignal and strategy.position_size > 0, title="UT Sell", text="UT SELL", style=shape.labeldown, location=location.abovebar, size=size.tiny)
